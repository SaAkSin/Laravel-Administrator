{
	"name": "saaksin/laravel-administrator",
	"type": "library",
	"description": "데이터베이스 기반 라라벨 관리자 페이지",
	"homepage": "https://administrator.artgrammer.co.kr",
	"keywords": ["administrator", "admin", "laravel-administrator", "laravel"],
	"license": "MIT",
	"authors": [
		{
			"name": "GiSeok Lee",
			"email": "gslee@artgrammer.co.kr"
		}
	],
	"support": {
		"issues": "https://github.com/SaAkSin/Laravel-Administrator/issues",
		"source": "https://github.com/SaAkSin/Laravel-Administrator"
	},
	"config": {
		"platform": {
			"php": "8.3.0"
		}
	},
	"require": {
		"php": "^8.3",
		"laravel/framework": "^13.0"
	},
	"autoload": {
		"classmap": [
			"src/controllers"
		],
		"psr-0": {
			"SaAkSin\\Administrator": "src/"
		}
	},
	"extra": {
		"laravel": {
			"providers": [
				"SaAkSin\\Administrator\\AdministratorServiceProvider"
			]
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"mockery/mockery": "^1.6",
		"orchestra/testbench": "^11.0",
		"laravel/octane": "^2.0"
	}
}
